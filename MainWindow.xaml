<Window x:Class="FerrariX.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="FerrariX"
        Height="640" Width="920"
        MinHeight="460" MinWidth="660"
        Background="#0d1117"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">

    <Window.Resources>

        <!-- Botón principal (rojo Ferrari) -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#cc0000"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#e60000"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#aa0000"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#2d2d2d"/>
                                <Setter Property="Foreground" Value="#555555"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Botón secundario (gris oscuro) -->
        <Style x:Key="SecondaryBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#21262d"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}"
                                BorderBrush="#30363d"
                                BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#30363d"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#161b22"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="54"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <!-- ─── Header ─── -->
        <Border Grid.Row="0" Background="#161b22" BorderBrush="#30363d" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                    <TextBlock Text="Ferrari" Foreground="#ff2222" FontSize="22"
                               FontWeight="Bold" FontFamily="Segoe UI"/>
                    <TextBlock Text="X" Foreground="White" FontSize="22"
                               FontWeight="Bold" FontFamily="Segoe UI"/>
                </StackPanel>

                <!-- Estado de conexión -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                    <Ellipse x:Name="StatusDot" Width="10" Height="10"
                             Fill="#ef4444" VerticalAlignment="Center"/>
                    <TextBlock x:Name="StatusLabel" Text="Sin Conexión"
                               Foreground="#9ca3af" FontSize="12"
                               VerticalAlignment="Center" Margin="8,0,0,0"
                               FontFamily="Segoe UI"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ─── Monaco Editor ─── -->
        <Border Grid.Row="1" BorderBrush="#30363d" BorderThickness="0,0,0,1">
            <wv2:WebView2 x:Name="MonacoEditor"/>
        </Border>

        <!-- ─── Barra de botones ─── -->
        <Border Grid.Row="2" Background="#161b22">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0">
                <Button x:Name="ExecuteBtn"
                        Content="▶  Ejecutar"
                        Style="{StaticResource PrimaryBtn}"
                        Click="ExecuteBtn_Click"
                        MinWidth="120"/>
                <Button x:Name="ClearBtn"
                        Content="Limpiar"
                        Style="{StaticResource SecondaryBtn}"
                        Click="ClearBtn_Click"
                        Margin="8,0,0,0" MinWidth="90"/>
                <Button x:Name="OpenBtn"
                        Content="Abrir"
                        Style="{StaticResource SecondaryBtn}"
                        Click="OpenBtn_Click"
                        Margin="8,0,0,0" MinWidth="80"/>
                <Button x:Name="SaveBtn"
                        Content="Guardar"
                        Style="{StaticResource SecondaryBtn}"
                        Click="SaveBtn_Click"
                        Margin="8,0,0,0" MinWidth="90"/>
            </StackPanel>
        </Border>

        <!-- ─── Status bar ─── -->
        <Border Grid.Row="3" Background="#0d1117" BorderBrush="#21262d" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText"
                           Grid.Column="0"
                           Foreground="#6b7280"
                           FontSize="11"
                           FontFamily="Consolas"
                           VerticalAlignment="Center"
                           Margin="12,0"/>
                <TextBlock x:Name="ClientsText"
                           Grid.Column="1"
                           Foreground="#6b7280"
                           FontSize="11"
                           FontFamily="Consolas"
                           VerticalAlignment="Center"
                           Margin="12,0"/>
            </Grid>
        </Border>

    </Grid>
</Window>
